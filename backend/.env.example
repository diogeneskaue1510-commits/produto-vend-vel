# Copie este arquivo para .env e preencha os valores

# Banco de dados PostgreSQL (Railway fornece automaticamente)
DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# Segredo do JWT - use uma string longa e aleatória
JWT_SECRET=coloque_uma_chave_secreta_longa_aqui_123456

# Porta do servidor
PORT=3001

# Ambiente
NODE_ENV=production
